{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    },
    "color": {
      "custom": true,
      "link": true,
      "palette": [
        {
          "slug": "primary",
          "color": "#030a8c",
          "name": "Primary (Dark Blue)"
        },
        {
          "slug": "secondary",
          "color": "#020873",
          "name": "Secondary (Blue)"
        },
        {
          "slug": "black",
          "color": "#232323",
          "name": "Black"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "light",
          "color": "#fafafa",
          "name": "Light Grey"
        }
      ]
    },
    "typography": {
      "customFontSize": true,
      "lineHeight": true,
      "fontFamilies": [
        {
          "fontFamily": "\"Epilogue\", sans-serif",
          "slug": "headings",
          "name": "Epilogue (Headings)"
        },
        {
          "fontFamily": "\"Jost\", sans-serif",
          "slug": "body",
          "name": "Jost (Body)"
        }
      ]
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "margin": true,
      "padding": true,
      "units": [ "%", "px", "em", "rem", "vh", "vw" ]
    }
  }
}
